#!/usr/bin/env python3
import sys
import struct
import subprocess
import tempfile
import os
from urllib.request import url2pathname
from urllib.parse import urlparse


def find_sqlite_chunk(data):
    if not data.startswith(b'CSFCHUNK'):
        return None
    pos = 0x18
    while pos + 16 <= len(data):
        name = data[pos:pos+8]
        size = struct.unpack('>Q', data[pos+8:pos+16])[0]
        if name == b'CHNKSQLi':
            return data[pos+16:pos+16+size]
        pos += 16 + size
    return None


def main():
    if len(sys.argv) < 3:
        sys.exit(1)

    input_arg, output_path = sys.argv[1], sys.argv[2]
    size = sys.argv[3] if len(sys.argv) > 3 else '128'

    # gnome-desktop passes a local path inside the sandbox; handle URIs too
    parsed = urlparse(input_arg)
    input_path = url2pathname(parsed.path) if parsed.scheme == 'file' else input_arg

    with open(input_path, 'rb') as f:
        data = f.read()

    sqlite_data = find_sqlite_chunk(data)
    if sqlite_data is None:
        sys.exit(1)

    with tempfile.NamedTemporaryFile(suffix='.db', delete=False) as db_tmp:
        db_tmp.write(sqlite_data)
        db_path = db_tmp.name

    png_path = db_path + '.png'

    try:
        result = subprocess.run(
            ['/usr/bin/sqlite3', db_path,
             f"SELECT writefile('{png_path}', ImageData) FROM CanvasPreview LIMIT 1;"],
            capture_output=True
        )
        if result.returncode != 0 or not os.path.exists(png_path):
            sys.exit(1)

        # ImageMagick rejects Clip Studio's PNG filter bytes; ffmpeg handles them fine
        result = subprocess.run(
            ['/usr/bin/ffmpeg', '-i', png_path,
             '-vf', f'scale={size}:-1',
             '-update', '1', '-frames:v', '1',
             output_path, '-y'],
            capture_output=True
        )
        sys.exit(result.returncode)
    finally:
        for path in (db_path, png_path):
            if os.path.exists(path):
                os.unlink(path)


if __name__ == '__main__':
    main()
